---
// src/components/Waline.astro
const serverURL = import.meta.env.PUBLIC_WALINE_SERVER_URL;
const currentPath = Astro.url.pathname;
const isConfigured = !!serverURL;

// 更好的环境变量检查
const isDevelopment = import.meta.env.DEV;
---

{isConfigured ? (
  <>
    <div id="waline-container" class="waline-wrapper">
      <div id="waline"></div>
    </div>

    <!-- Waline 样式 -->
    <link rel="stylesheet" href="https://unpkg.com/@waline/client@2/dist/waline.css" />

    <!-- Waline 初始化 -->
    <script
      type="module"
      is:inline
      define:vars={{ serverURL, currentPath, isDevelopment }}
    >
      // 开发模式下的调试信息
      if (isDevelopment) {
        console.log('🎯 Waline 服务器地址:', serverURL);
        console.log('📄 当前路径:', currentPath);
      }

      // 动态加载 Waline
      import('https://unpkg.com/@waline/client@2/dist/waline.mjs')
        .then(({ init }) => {
          init({
            el: '#waline',
            serverURL,
            path: currentPath,
            lang: 'zh-CN',
            login: 'enable',   // 可改为 'enable'
            dark: document.documentElement.classList.contains('dark'),

            // 可选配置
            comment: true,
            pageview: true,
            meta: ['nick', 'mail', 'link'],
            requiredMeta: ['nick'],
            locale: {
              placeholder: '欢迎留言讨论...',
              nick: '昵称',
              mail: '邮箱',
              link: '网址',
            },
            emoji: [
              '//unpkg.com/@waline/emojis@1/weibo',
              '//unpkg.com/@waline/emojis@1/qq',
            ],
            reaction: true, // 新增：启用表情反应
            search: false,  // 评论搜索功能
            
            // 错误处理
            errorHandler: (error) => {
              console.error('💥 Waline 错误:', error);
            },
            
            // 成功回调（可选）
            successHandler: () => {
              if (isDevelopment) {
                console.log('✅ Waline 加载成功');
              }
            }
          });
        })
        .catch(err => {
          console.error('❌ Waline 加载失败:', err);
        });
    </script>
  </>
) : (
  <div class="p-6 bg-yellow-50 border border-yellow-200 rounded-xl">
    <h3 class="text-lg font-medium text-yellow-800">Waline 未配置</h3>
    <p class="mt-2 text-yellow-700">
      请在 <code>.env</code> 中设置
      <code class="mx-1 px-2 py-1 bg-yellow-100 rounded">
        PUBLIC_WALINE_SERVER_URL
      </code>
    </p>
    {isDevelopment && (
      <div class="mt-4 p-4 bg-blue-50 border border-blue-200 rounded">
        <p class="text-blue-700 text-sm">
          💡 提示：在开发模式下，你可以在 <code>.env.local</code> 中临时设置环境变量
        </p>
      </div>
    )}
  </div>
)}

<style>
  .waline-wrapper {
    margin-top: 1rem;
  }
  
  #waline {
    --waline-theme-color: #dc2626;
    --waline-active-color: #b91c1c;
    --waline-bgcolor: #fafafa;
    --waline-bgcolor-light: #ffffff;
    --waline-border-color: #e5e7eb;
    --waline-border-radius: 12px;
    --waline-box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  }
  
  :global(.dark) #waline {
    --waline-theme-color: #f87171;
    --waline-active-color: #ef4444;
    --waline-bgcolor: #1f2937;
    --waline-bgcolor-light: #374151;
    --waline-border-color: #4b5563;
    --waline-text-color: #e5e7eb;
  }
</style>