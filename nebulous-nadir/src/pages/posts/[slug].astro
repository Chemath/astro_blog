---
// src/pages/posts/[slug].astro
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { normalizeDate } from '../../utils/date.js';
import Waline from '../../components/Waline.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

// 获取相关文章用于推荐
const allPosts = await getCollection('posts');
const sortedPosts = allPosts
  .filter(p => p.id !== post.id)
  .sort((a, b) => {
    const dateA = normalizeDate(a.data.date).getTime();
    const dateB = normalizeDate(b.data.date).getTime();
    return dateB - dateA;
  })
  .slice(0, 3);

// 计算阅读时间
const words = post.body.split(/\s+/).length;
const readingTime = Math.ceil(words / 250);

// 格式化日期 - 使用 normalizeDate 函数
const formatDate = (dateInput) => {
  return normalizeDate(dateInput).toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<Layout pageTitle={post.data.title}>
  <!-- 简单的面包屑导航 -->
  <nav class="mb-8">
    <ol class="flex items-center text-sm text-neutral-500">
      <li>
        <a href="/" class="hover:text-red-600 transition-colors">首页</a>
      </li>
      <li class="mx-2">/</li>
      <li>
        <a href="/posts" class="hover:text-red-600 transition-colors">文章</a>
      </li>
      <li class="mx-2">/</li>
      <li class="text-neutral-900 font-medium truncate max-w-xs">
        {post.data.title}
      </li>
    </ol>
  </nav>

  <!-- 两栏布局 -->
  <div class="lg:flex lg:gap-12">
    <!-- 主内容区 -->
    <article class="lg:flex-1 max-w-3xl mx-auto">
      <header class="mb-12 pt-4">
        
        <!-- 标题 -->
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-neutral-900 mb-6 leading-tight">
          {post.data.title}
        </h1>

        <!-- 元信息 -->
        <div class="flex items-center justify-between text-sm text-neutral-600 pb-8 border-b border-neutral-200">
          <div class="flex items-center space-x-6">
            <div class="flex items-center space-x-2">
              <svg class="w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <time datetime={normalizeDate(post.data.date).toISOString()}>
                {formatDate(post.data.date)}
              </time>
            </div>
            <div class="flex items-center space-x-2">
              <svg class="w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>{readingTime} 分钟阅读</span>
            </div>
          </div>
          
          <button
            onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
            class="hidden md:inline-flex items-center space-x-1 text-neutral-500 hover:text-neutral-700 transition-colors"
            aria-label="回到顶部"
          >
            <span class="text-sm">顶部</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
            </svg>
          </button>
        </div>
      </header>

      <!-- 文章内容 -->
      <div class="prose-article mb-16">
        {post.data.description && (
          <div class="not-prose bg-gradient-to-r from-red-50 to-orange-50 p-6 rounded-xl mb-8 border-l-4 border-red-400">
            <p class="text-lg text-neutral-700 font-medium">
              {post.data.description}
            </p>
          </div>
        )}

        <Content />

        <!-- 文章结束标志 -->
        <div class="not-prose mt-16 pt-8 border-t border-neutral-200 text-center">
          <div class="inline-flex items-center space-x-2 text-neutral-500">
            <div class="w-6 h-px bg-gradient-to-r from-transparent via-neutral-300 to-transparent"></div>
            <span class="text-sm">正文结束</span>
            <div class="w-6 h-px bg-gradient-to-r from-transparent via-neutral-300 to-transparent"></div>
          </div>
        </div>
      </div>

      <!-- ================= 在这里添加 Waline 评论 ================= -->
  <section class="mt-16 pt-12 border-t border-neutral-200">
    <div class="flex items-center space-x-3 mb-8">
      <div class="w-8 h-8 bg-gradient-to-r from-red-100 to-orange-100 rounded-full flex items-center justify-center">
        <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
        </svg>
      </div>
      <h3 class="text-xl font-bold text-neutral-900">评论</h3>
      <span class="text-sm text-neutral-500 px-2 py-1 bg-neutral-100 rounded">
        共 <span class="waline-comment-count font-medium">0</span> 条评论
      </span>
    </div>
    
    <!-- 使用 Waline 组件，传递当前文章路径 -->
    <Waline path={`/posts/${post.slug}`} />
  </section>
  <!-- ================= Waline 评论结束 ================= -->
      

     <!-- 相关文章推荐 -->
{sortedPosts.length > 0 && (
  <div class="mt-16 pt-12 border-t border-neutral-200">
    <h3 class="text-xl font-bold text-neutral-900 mb-8">推荐阅读</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {sortedPosts.map((relatedPost) => {
        const postDate = normalizeDate(relatedPost.data.date);
        const year = postDate.getFullYear();
        const month = String(postDate.getMonth() + 1).padStart(2, '0');
        const day = String(postDate.getDate()).padStart(2, '0');
        const formattedDate = `${year}-${month}-${day}`;
        
        return (
          <a 
            href={`/posts/${relatedPost.slug}`}
            class="group block p-5 border border-neutral-200 rounded-xl hover:border-red-200 hover:shadow-md transition-all"
          >
            <div class="text-sm text-neutral-500 mb-3">
              {formattedDate}
            </div>
            <h4 class="font-medium text-neutral-900 group-hover:text-red-600 transition-colors mb-2 line-clamp-2">
              {relatedPost.data.title}
            </h4>
            {relatedPost.data.description && (
              <p class="text-sm text-neutral-600 line-clamp-2">
                {relatedPost.data.description}
              </p>
            )}
          </a>
        );
      })}
    </div>
  </div>
)}

      <!-- 导航链接 -->
      <div class="mt-16 pt-8 border-t border-neutral-200">
        <div class="flex justify-between">
          <a 
            href="/posts"
            class="inline-flex items-center space-x-2 text-neutral-600 hover:text-red-600 transition-colors"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            <span>返回文章列表</span>
          </a>
          
          <button
            onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
            class="inline-flex items-center space-x-2 text-neutral-600 hover:text-red-600 transition-colors"
            aria-label="回到顶部"
          >
            <span>回到顶部</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 15l7-7 7 7" />
            </svg>
          </button>
        </div>
      </div>
    </article>

    <!-- 侧边栏目录 -->
    <aside class="hidden lg:block w-64 flex-shrink-0">
      <div class="sticky top-24 pt-8">
        <!-- 目录组件内联实现 -->
        <nav class="not-prose" aria-label="文章目录">
          <div class="sticky top-24">
            <div class="mb-4 pb-3 border-b border-neutral-200">
              <div class="flex items-center space-x-2">
                <svg class="w-4 h-4 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
                <h3 class="text-sm font-semibold text-neutral-900">目录</h3>
              </div>
            </div>

            {headings && headings.filter(h => h.depth === 2 || h.depth === 3).length > 0 ? (
              <ul class="space-y-2 text-sm">
                {headings.filter(h => h.depth === 2 || h.depth === 3).map((heading) => (
                  <li 
                    class={`${heading.depth === 3 ? 'ml-4' : ''}`}
                    style={{
                      paddingLeft: heading.depth === 3 ? '1rem' : '0'
                    }}
                  >
                    <a 
                      href={`#${heading.slug}`}
                      class="group flex items-center py-1.5 text-neutral-600 hover:text-red-600 transition-colors"
                    >
                      <div class="w-1.5 h-1.5 rounded-full bg-neutral-300 group-hover:bg-red-400 transition-colors mr-2 flex-shrink-0"></div>
                      <span class="truncate">{heading.text}</span>
                    </a>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="text-sm text-neutral-500 italic">本文暂无标题</p>
            )}

            <!-- 目录底部提示 -->
            <div class="mt-6 pt-4 border-t border-neutral-200">
              <div class="text-xs text-neutral-500">
                <div class="flex items-center space-x-1 mb-1">
                  <div class="w-2 h-2 rounded-full bg-neutral-400"></div>
                  <span>主要章节</span>
                </div>
                <div class="flex items-center space-x-1">
                  <div class="w-2 h-2 rounded-full bg-neutral-300 ml-4"></div>
                  <span>子章节</span>
                </div>
              </div>
            </div>
          </div>
        </nav>
      </div>
    </aside>
  </div>
</Layout>

<style is:global>
  /* 文章内容样式优化 */
  .prose-article {
    font-size: 1.125rem;
    line-height: 1.75;
    color: #374151;
  }
  
  .prose-article > * + * {
    margin-top: 1.75em;
  }
  
  /* 段落 */
  .prose-article p {
    margin-bottom: 0;
  }
  
  /* 标题 */
  .prose-article h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1f2937;
    margin-top: 2.5em;
    margin-bottom: 0.75em;
    padding-bottom: 0.5em;
    border-bottom: 2px solid #f3f4f6;
    scroll-margin-top: 100px;
  }
  
  .prose-article h3 {
    font-size: 1.5rem;
    font-weight: 600;
    color: #1f2937;
    margin-top: 2em;
    margin-bottom: 0.5em;
    scroll-margin-top: 100px;
  }
  
  .prose-article h4 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #374151;
    margin-top: 1.5em;
    margin-bottom: 0.5em;
    scroll-margin-top: 100px;
  }
  
  /* 链接 */
  .prose-article a {
    color: #dc2626;
    text-decoration: none;
    border-bottom: 1px solid #fca5a5;
    transition: all 0.2s;
  }
  
  .prose-article a:hover {
    color: #b91c1c;
    border-bottom-color: #dc2626;
  }
  
  /* 强调 */
  .prose-article strong {
    color: #111827;
    font-weight: 600;
  }
  
  .prose-article em {
    font-style: italic;
    color: #4b5563;
  }
  
  /* 引用 */
  .prose-article blockquote {
    border-left: 4px solid #f3f4f6;
    padding-left: 1.5em;
    margin: 2em 0;
    font-style: normal;
    color: #6b7280;
    background-color: #f9fafb;
    padding: 1.5em;
    border-radius: 0.5em;
    border-left-color: #dc2626;
  }
  
  .prose-article blockquote p {
    margin: 0;
  }
  
  /* 代码 */
  .prose-article :not(pre) > code {
    background-color: #fef2f2;
    color: #dc2626;
    padding: 0.2em 0.4em;
    border-radius: 0.25em;
    font-size: 0.9em;
    font-family: 'SF Mono', Monaco, Consolas, 'Liberation Mono', monospace;
    font-weight: 500;
  }
  
  .prose-article pre {
    background-color: #1f2937;
    color: #e5e7eb;
    padding: 1.5em;
    border-radius: 0.5em;
    overflow-x: auto;
    margin: 2em 0;
    font-size: 0.9em;
    line-height: 1.6;
  }
  
  .prose-article pre code {
    background-color: transparent;
    color: inherit;
    padding: 0;
    font-size: inherit;
    font-weight: normal;
  }
  
  /* 列表 */
  .prose-article ul,
  .prose-article ol {
    padding-left: 1.75em;
    margin: 1.5em 0;
  }
  
  .prose-article li {
    margin-bottom: 0.5em;
    padding-left: 0.5em;
  }
  
  .prose-article ul > li::marker {
    color: #dc2626;
  }
  
  .prose-article ol > li::marker {
    color: #dc2626;
    font-weight: 600;
  }
  
  /* 图片 */
  .prose-article img {
    border-radius: 0.75em;
    margin: 2.5em 0;
    width: 100%;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }
  
  /* 分隔线 */
  .prose-article hr {
    border: none;
    border-top: 2px solid #f3f4f6;
    margin: 3em 0;
  }
  
  /* 表格 */
  .prose-article table {
    width: 100%;
    border-collapse: collapse;
    margin: 2.5em 0;
    font-size: 0.95em;
  }
  
  .prose-article thead {
    border-bottom: 2px solid #e5e7eb;
  }
  
  .prose-article th {
    padding: 0.75em 1em;
    text-align: left;
    font-weight: 600;
    color: #111827;
    background-color: #f9fafb;
  }
  
  .prose-article td {
    padding: 0.75em 1em;
    border-bottom: 1px solid #f3f4f6;
  }
  
  .prose-article tbody tr:hover {
    background-color: #f9fafb;
  }
  
  /* 响应式 */
  @media (max-width: 768px) {
    .prose-article {
      font-size: 1.0625rem;
      line-height: 1.7;
    }
    
    .prose-article h2 {
      font-size: 1.5rem;
      margin-top: 2em;
    }
    
    .prose-article h3 {
      font-size: 1.25rem;
      margin-top: 1.75em;
    }
    
    .prose-article h4 {
      font-size: 1.125rem;
    }
  }
  
  /* 截断文本 */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>