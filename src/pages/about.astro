---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';

// 时间线数据
const timeline = [
  { year: '现在', event: '学习ing', description: '成天瞎胡闹' },
  { year: '2024', event: '开始写博客', description: '记录学习和生活的点滴' },
  { year: '2018', event: '接触编程', description: '第一次写下了Hello World' },
];

---

<Layout pageTitle="关于我">
  <!-- 和首页完全一致的头部 -->
  <div class="mb-16 pt-8">
    <h1 class="text-4xl font-bold text-neutral-900 mb-4">
      About
    </h1>
    <div class="h-1 w-16 bg-gradient-to-r from-red-500 to-orange-400 mb-6"></div>
    <p class="text-lg text-neutral-600 max-w-xl">
      你好，我是 Chemath。这个博客是我思考的延伸。
    </p>
  </div>

  <div class="max-w-4xl">
    <!-- 主要介绍 -->
    <div class="mb-20">
      <div class="prose prose-lg max-w-none mb-12">
        <p>
          你好，我是 <span class="font-bold text-red-600">Chemath</span>。和许多同龄人一样，我走在探索世界的路上。
        </p>
        <p>
          这个博客是我思考的延伸，记录着学习过程中的收获、生活里的感悟，以及偶尔的奇思妙想。
        </p>
        <p>
          我享受学习新知识的过程，也乐于分享自己的见解。希望在这里，你能找到一些共鸣或启发。
        </p>
      </div>

      <!-- 分割线 -->
      <div class="my-12">
        <div class="flex items-center justify-center">
          <div class="w-24 h-px bg-gradient-to-r from-transparent via-neutral-300 to-transparent"></div>
          <div class="mx-4 text-neutral-400">• • •</div>
          <div class="w-24 h-px bg-gradient-to-r from-transparent via-neutral-300 to-transparent"></div>
        </div>
      </div>

      <!-- 时间线 -->
      <div class="mb-20">
        <h2 class="text-2xl font-medium text-neutral-900 mb-8">时间线</h2>
        
        <div class="relative">
          <!-- 时间轴线 -->
          <div class="absolute left-4 md:left-6 top-0 bottom-0 w-0.5 bg-gradient-to-b from-red-500 via-orange-400 to-transparent"></div>
          
          {timeline.map((item, index) => (
            <div class="relative mb-12 last:mb-0">
              <div class="flex items-start">
                <!-- 时间点 -->
                <div class="relative z-10 flex-shrink-0">
                  <div class="w-8 h-8 md:w-10 md:h-10 rounded-full bg-white border-2 border-red-500 flex items-center justify-center">
                    <div class="w-3 h-3 md:w-4 md:h-4 rounded-full bg-gradient-to-r from-red-500 to-orange-400"></div>
                  </div>
                </div>
                
                <!-- 内容 -->
                <div class="ml-6 md:ml-10 flex-1 pt-1">
                  <div class="mb-2">
                    <span class="text-lg font-bold text-red-600">{item.year}</span>
                    <span class="text-xl font-medium text-neutral-900 ml-3">{item.event}</span>
                  </div>
                  <p class="text-neutral-600 leading-relaxed">
                    {item.description}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- 联系或更多 -->
      <div class="bg-gradient-to-br from-red-50 to-orange-50 rounded-xl p-8 mb-16">
        <div class="text-center max-w-2xl mx-auto">
          <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center mx-auto mb-6 shadow-sm">
            <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
          </div>
          
          <h3 class="text-2xl font-medium text-neutral-900 mb-4">保持联系</h3>
          <p class="text-neutral-600 mb-6 leading-relaxed">
            如果你对我的文章有任何想法，欢迎通过评论联系我。
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a 
              href="/posts"
              class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-red-600 bg-white hover:bg-red-50 border border-red-200 rounded-lg transition-colors"
            >
              阅读我的文章
            </a>
            <a 
              href="/"
              class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-neutral-700 bg-white hover:bg-neutral-50 border border-neutral-200 rounded-lg transition-colors"
            >
              返回首页
            </a>
          </div>
        </div>
      </div>

      <!-- 结语 -->
      <div class="prose prose-lg max-w-none text-center py-8">
        <p class="text-neutral-600 italic">
          感谢你的阅读，希望在这里你能找到一些有价值的内容。
        </p>
        <p class="text-sm text-neutral-500 mt-4">
          — Chemath
        </p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .prose p {
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }
  
  .prose p:last-child {
    margin-bottom: 0;
  }
</style>