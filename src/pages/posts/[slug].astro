---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import Waline from '../../components/Waline.astro';
import { normalizeDate } from '../../utils/date.js';

export async function getStaticPaths() {
  const posts = await getCollection('posts');

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const relatedPosts = (await getCollection('posts'))
  .filter((entry) => entry.id !== post.id)
  .sort((a, b) => normalizeDate(b.data.date).getTime() - normalizeDate(a.data.date).getTime())
  .slice(0, 3);

const readingTime = Math.max(1, Math.ceil(post.body.split(/\s+/).length / 250));

const formatDate = (value) =>
  normalizeDate(value).toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });

const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<Layout pageTitle={post.data.title}>
  <nav class="mb-8 text-sm text-neutral-500">
    <a href="/" class="hover:text-red-600 transition-colors">首页</a>
    <span class="mx-2">/</span>
    <a href="/posts" class="hover:text-red-600 transition-colors">文章</a>
    <span class="mx-2">/</span>
    <span class="text-neutral-900">{post.data.title}</span>
  </nav>

  <div class="lg:flex lg:gap-12">
    <article class="min-w-0 flex-1 max-w-3xl">
      <header class="mb-10 border-b border-neutral-200 pb-8">
        <h1 class="mb-6 text-3xl font-bold leading-tight text-neutral-900 md:text-4xl lg:text-5xl">
          {post.data.title}
        </h1>

        <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-neutral-600">
          <time datetime={normalizeDate(post.data.date).toISOString()}>
            {formatDate(post.data.date)}
          </time>
          <span>{readingTime} 分钟阅读</span>
        </div>

        {post.data.description && (
          <p class="mt-6 rounded-xl border-l-4 border-red-400 bg-gradient-to-r from-red-50 to-orange-50 p-5 text-lg text-neutral-700">
            {post.data.description}
          </p>
        )}
      </header>

      <div class="prose-article">
        <Content />
      </div>

      <section class="mt-16 border-t border-neutral-200 pt-10">
        <div class="mb-6 flex items-center justify-between gap-4">
          <h2 class="text-xl font-bold text-neutral-900">评论</h2>
          <span class="text-sm text-neutral-500">
            共 <span class="waline-comment-count" data-path={Astro.url.pathname}>0</span> 条评论
          </span>
        </div>
        <Waline />
      </section>

      {relatedPosts.length > 0 && (
        <section class="mt-16 border-t border-neutral-200 pt-10">
          <h2 class="mb-6 text-xl font-bold text-neutral-900">推荐阅读</h2>
          <div class="grid gap-6 md:grid-cols-3">
            {relatedPosts.map((relatedPost) => (
              <a
                href={`/posts/${relatedPost.id}`}
                class="group block rounded-xl border border-neutral-200 p-5 transition-all hover:border-red-200 hover:shadow-md"
              >
                <div class="mb-3 text-sm text-neutral-500">
                  {normalizeDate(relatedPost.data.date).toLocaleDateString('zh-CN', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit',
                  })}
                </div>
                <h3 class="mb-2 font-medium text-neutral-900 transition-colors group-hover:text-red-600">
                  {relatedPost.data.title}
                </h3>
                {relatedPost.data.description && (
                  <p class="line-clamp-2 text-sm text-neutral-600">{relatedPost.data.description}</p>
                )}
              </a>
            ))}
          </div>
        </section>
      )}
    </article>

    <aside class="mt-12 hidden w-64 shrink-0 lg:block">
      <div class="sticky top-24 rounded-xl border border-neutral-200 bg-white p-5">
        <h2 class="mb-4 text-sm font-semibold text-neutral-900">目录</h2>
        {tocHeadings.length > 0 ? (
          <ul class="space-y-2 text-sm">
            {tocHeadings.map((heading) => (
              <li class={heading.depth === 3 ? 'ml-4' : ''}>
                <a
                  href={`#${heading.slug}`}
                  class="block text-neutral-600 transition-colors hover:text-red-600"
                >
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <p class="text-sm text-neutral-500">本文暂无目录。</p>
        )}
      </div>
    </aside>
  </div>
</Layout>

<style is:global>
  .prose-article {
    color: #374151;
    font-size: 1.125rem;
    line-height: 1.75;
  }

  .prose-article > * + * {
    margin-top: 1.75em;
  }

  .prose-article h2,
  .prose-article h3,
  .prose-article h4 {
    color: #111827;
    line-height: 1.3;
    scroll-margin-top: 96px;
  }

  .prose-article h2 {
    margin-top: 2.5em;
    border-bottom: 2px solid #f3f4f6;
    padding-bottom: 0.5em;
    font-size: 1.75rem;
    font-weight: 700;
  }

  .prose-article h3 {
    margin-top: 2em;
    font-size: 1.5rem;
    font-weight: 600;
  }

  .prose-article h4 {
    margin-top: 1.5em;
    font-size: 1.25rem;
    font-weight: 600;
  }

  .prose-article a {
    color: #dc2626;
    text-decoration: none;
    border-bottom: 1px solid #fca5a5;
    transition: all 0.2s;
  }

  .prose-article a:hover {
    color: #b91c1c;
    border-bottom-color: #dc2626;
  }

  .prose-article blockquote {
    margin: 2em 0;
    border-left: 4px solid #dc2626;
    border-radius: 0.5em;
    background: #f9fafb;
    padding: 1.5em;
    color: #6b7280;
  }

  .prose-article :not(pre) > code {
    border-radius: 0.25em;
    background: #fef2f2;
    padding: 0.2em 0.4em;
    color: #dc2626;
    font-size: 0.9em;
  }

  .prose-article pre {
    overflow-x: auto;
    border-radius: 0.5em;
    background: #1f2937;
    padding: 1.5em;
    color: #e5e7eb;
    font-size: 0.9em;
    line-height: 1.6;
  }

  .prose-article pre code {
    background: transparent;
    color: inherit;
    padding: 0;
  }

  .prose-article ul,
  .prose-article ol {
    margin: 1.5em 0;
    padding-left: 2em;
  }

  .prose-article li {
    margin-bottom: 0.75em;
  }

  .prose-article img {
    width: 100%;
    border-radius: 0.75em;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .prose-article table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95em;
  }

  .prose-article th,
  .prose-article td {
    border-bottom: 1px solid #f3f4f6;
    padding: 0.75em 1em;
    text-align: left;
  }

  .prose-article th {
    background: #f9fafb;
    color: #111827;
    font-weight: 600;
  }

  .line-clamp-2 {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  @media (max-width: 768px) {
    .prose-article {
      font-size: 1.0625rem;
      line-height: 1.7;
    }

    .prose-article h2 {
      font-size: 1.5rem;
    }

    .prose-article h3 {
      font-size: 1.25rem;
    }
  }
</style>
